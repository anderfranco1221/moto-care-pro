{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2023",
    "strict": true,                         // Activa todas las comprobaciones estrictas
    "noImplicitAny": true,                 // Prohíbe el uso de 'any' implícito
    "strictNullChecks": true,              // Te obliga a manejar null/undefined
    "strictPropertyInitialization": true,  // Obliga a inicializar variables en clases
    "noUnusedLocals": true,                // Te avisa si declaras una variable y no la usas
    "noUnusedParameters": true,            // Te avisa si una función recibe parámetros que no usa
    
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "baseUrl": "./",
    "outDir": "./dist",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
